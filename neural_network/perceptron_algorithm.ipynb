   "source": [
    "import numpy as np\n",
    "\n",
    "def perceptron(X, y, epochs=1):\n",
    "    w = np.zeros(X.shape[1])\n",
    "    b = 0\n",
    "\n",
    "    for _ in range(epochs):\n",
    "        for i in range(len(X)):\n",
    "            if y[i] * (np.dot(w, X[i]) + b) <= 0:\n",
    "                w += y[i] * X[i]\n",
    "                b += y[i]\n",
    "\n",
    "    return w, b"
   ]
  }
 ],
